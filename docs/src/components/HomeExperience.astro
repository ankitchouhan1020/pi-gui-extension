<script>
  const stages = {
    command: {
      label: "/gui · attach",
      copy: "Starts the local host inside pi and attaches the current live terminal session.",
    },
    browser: {
      label: "Browser · interact",
      copy: "Sends commands over REST and receives ordered agent events over a resumable SSE stream.",
    },
    hub: {
      label: "SessionHub · coordinate",
      copy: "Keeps multiple sessions open, serializes turns per session, and protects live-writer ownership.",
    },
    agent: {
      label: "AgentSession · run",
      copy: "Pi owns the model, tools, skills, extensions, authentication, and durable session history.",
    },
  } as const;

  class PiFlow extends HTMLElement {
    connectedCallback() {
      const label = this.querySelector<HTMLElement>("[data-stage-label]");
      const copy = this.querySelector<HTMLElement>("[data-stage-copy]");
      const buttons = [...this.querySelectorAll<HTMLButtonElement>("button[data-stage]")];

      for (const button of buttons) {
        button.addEventListener("click", () => {
          const stage = stages[button.dataset.stage as keyof typeof stages];
          if (!stage || !label || !copy) return;
          for (const item of buttons) item.setAttribute("aria-pressed", String(item === button));
          label.textContent = stage.label;
          copy.textContent = stage.copy;
        });
      }
    }
  }

  class InstallCommand extends HTMLElement {
    connectedCallback() {
      const button = this.querySelector<HTMLButtonElement>("button");
      const label = button?.querySelector("span");
      const status = this.querySelector<HTMLElement>(".copy-status");
      button?.addEventListener("click", async () => {
        await navigator.clipboard.writeText("pi install npm:pi-gui-extension");
        if (label) label.textContent = "Copied";
        if (status) status.textContent = "Install command copied";
        window.setTimeout(() => {
          if (label) label.textContent = "Copy";
          if (status) status.textContent = "";
        }, 1800);
      });
    }
  }

  if (!customElements.get("pi-flow")) customElements.define("pi-flow", PiFlow);
  if (!customElements.get("install-command")) customElements.define("install-command", InstallCommand);
</script>

