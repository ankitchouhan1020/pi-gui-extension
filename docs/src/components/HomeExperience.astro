          <strong>SessionHub</strong>
          <small>coordinate</small>
        </button>
        <span class="flow-line"><i></i></span>
        <button type="button" data-stage="agent" aria-pressed="false">
          <span class="stage-index">04</span>
          <strong>AgentSession</strong>
          <small>run</small>
        </button>
      </div>
      <div class="flow-detail" aria-live="polite">
        <span data-stage-label>/gui · attach</span>
        <p data-stage-copy>Starts the local host inside pi and attaches the current live terminal session.</p>
      </div>
    </pi-flow>
  </section>

