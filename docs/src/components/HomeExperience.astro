<div class="home-experience not-content">
  <section class="proof-strip" aria-label="pi-gui operating principles">
    <div>
      <strong>127.0.0.1</strong>
      <span>local only</span>
    </div>
    <div>
      <strong>1 runtime</strong>
      <span>pi stays the agent</span>
    </div>
    <div>
      <strong>many sessions</strong>
      <span>one browser workspace</span>
    </div>
    <div>
      <strong>REST + SSE</strong>
      <span>small, inspectable surface</span>
    </div>
  </section>

  <section class="experience-section flow-section">
    <div class="section-heading">
      <p class="eyebrow">Live system map</p>
      <h2>Follow one turn through pi-gui</h2>
      <p>Select a stage to see what it owns. The browser remains a thin shell; agent power stays in pi.</p>
    </div>

    <pi-flow class="flow-demo">
      <div class="flow-track" aria-label="Request flow">
        <button type="button" data-stage="command" aria-pressed="true">
          <span class="stage-index">01</span>
          <strong>/gui</strong>
          <small>attach</small>
        </button>
        <span class="flow-line"><i></i></span>
        <button type="button" data-stage="browser" aria-pressed="false">
          <span class="stage-index">02</span>
          <strong>Browser</strong>
          <small>interact</small>
        </button>
        <span class="flow-line"><i></i></span>
        <button type="button" data-stage="hub" aria-pressed="false">
